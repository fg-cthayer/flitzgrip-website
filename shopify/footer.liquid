      <div class="fg-footer-brand">
        <a href="https://www.flitzgrip.com" class="fg-footer-logo">
          <img src="https://www.flitzgrip.com/assets/images/logo.png" alt="FlitzGrip">
          <span>FlitzGrip<sup>™</sup></span>
        </a>
        <p>Natural skin repair for hands that work hard. Handcrafted in Berlin from organic ingredients.</p>
        <a href="https://www.instagram.com/flitz.grip" target="_blank" rel="noopener noreferrer" class="fg-footer-ig">Instagram</a>
      </div>
      <div class="fg-footer-col">
        <h5>Product</h5>
        <ul>
          <li><a href="https://www.flitzgrip.com/#product">Skin Repair Bar</a></li>
          <li><a href="https://www.flitzgrip.com/#ingredients">Ingredients</a></li>
          <li><a href="https://www.flitzgrip.com/#howto">How to Use</a></li>
        </ul>
      </div>
      <div class="fg-footer-col">
        <h5>Company</h5>
        <ul>
          <li><a href="https://www.flitzgrip.com/#about">About</a></li>
          <li><a href="https://www.flitzgrip.com/distributor.html">Distributors</a></li>
          <li><a href="mailto:info@flitzgrip.com">Contact</a></li>
        </ul>
      </div>
      <div class="fg-footer-col">
        <h5>Legal</h5>
        <ul>
          <li><a href="https://www.flitzgrip.com/impressum.html">Impressum</a></li>
          <li><a href="https://www.flitzgrip.com/datenschutz.html">Datenschutz</a></li>
          <li><a href="https://www.flitzgrip.com/widerruf.html">Widerruf</a></li>
          <li><a href="https://www.flitzgrip.com/agb.html">AGB</a></li>
        </ul>
      </div>
    </div>
    <div class="fg-footer-bottom">
      <span>© 2026 FlitzGo LTX GmbH · Am Krögel 2, 10179 Berlin</span>
      <span>Made with chalk-dusted hands.</span>
    </div>
  </div>
</footer>

