<style>
  .fg-footer {
    background: #141414; border-top: 1px solid #272727;
    padding: 3rem 0 2rem;
    font-family: 'Inter', sans-serif;
  }
  .fg-footer-inner {
    width: 100%; max-width: 1280px;
    margin: 0 auto; padding: 0 clamp(1rem, 2.5vw, 2rem);
  }
  .fg-footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 2.5rem; padding-bottom: 3rem;
  }
  .fg-footer-logo {
    display: flex; align-items: center; gap: 0.6rem;
    font-family: 'Roboto', sans-serif; font-weight: 700;
    font-size: 1.5rem; letter-spacing: 0.04em;
    color: #FFFFFF; text-decoration: none; margin-bottom: 1rem;
  }
  .fg-footer-logo img { height: 48px; width: auto; max-width: none; filter: invert(1) brightness(0) invert(1); }
  .fg-footer-logo sup { font-size: 0.38em; vertical-align: 0.85em; font-weight: 400; opacity: 0.55; }
  .fg-footer-brand p { font-size: 0.85rem; color: #888; max-width: 240px; line-height: 1.7; margin: 0 0 0.75rem; }
  .fg-footer-ig {
    display: inline-block; font-size: 0.8rem; font-weight: 600;
    letter-spacing: 0.04em; color: #F0EFED; text-decoration: none;
    transition: opacity 0.2s;
  }
  .fg-footer-ig:hover { opacity: 0.7; }
  .fg-footer-col h5 {
    font-family: 'Roboto', sans-serif; font-size: 0.7rem; font-weight: 700;
    letter-spacing: 0.15em; text-transform: uppercase;
    color: #888; margin-bottom: 1.25rem;
  }
  .fg-footer-col ul { list-style: none; padding: 0; margin: 0; }
  .fg-footer-col ul li { margin-bottom: 0.6rem; }
  .fg-footer-col ul a {
    font-size: 0.9rem; color: rgba(240,239,237,0.6); text-decoration: none;
    transition: color 0.2s;
  }
  .fg-footer-col ul a:hover { color: #FFFFFF; }
  .fg-footer-bottom {
    display: flex; align-items: center; justify-content: space-between;
    padding: 2rem 0; border-top: 1px solid #272727;
    font-size: 0.8rem; color: #888;
  }
  @media (max-width: 900px) {
    .fg-footer-grid { grid-template-columns: 1fr 1fr; gap: 2rem; }
  }
  @media (max-width: 480px) {
    .fg-footer-grid { grid-template-columns: 1fr; }
    .fg-footer-bottom { flex-direction: column; gap: 0.5rem; text-align: center; }
  }
</style>

<footer class="fg-footer">
